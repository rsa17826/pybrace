{
  "name": "pybrace",
  "displayName": "pybrace",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.121.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:gdscript"
  ],
  "main": "./out/extension.js",
  "publisher": "rssaromeo",
  "contributes": {
    "contributes": {
      "configuration": {
        "title": "Rainbow Braces",
        "properties": {
          "rainbowBraces.colors": {
            "type": "array",
            "default": [
              "#e06c75",
              "#61afef",
              "#98c379",
              "#c678dd",
              "#d19a66",
              "#56b6c2"
            ],
            "description": "Colors cycled by nesting depth"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
